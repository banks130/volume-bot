# =============================================
# VOLUME BOT — Environment Configuration
# =============================================

# Your MAIN funding wallet private key (base58)
PRIVATE_KEY=YOUR_MAIN_WALLET_PRIVATE_KEY_BASE58

# Solana RPC endpoint (use a fast private RPC for best results)
RPC_ENDPOINT=https://api.mainnet-beta.solana.com
RPC_WS_ENDPOINT=wss://api.mainnet-beta.solana.com

# Set to "mainnet-beta" or "devnet"
NETWORK=mainnet-beta

# Server port
PORT=3001

# Jupiter API (public endpoint — no key needed)
JUPITER_API=https://quote-api.jup.ag/v6

# Priority fee in microlamports (higher = faster confirms)
PRIORITY_FEE=100000

# Slippage in basis points (100 = 1%, 300 = 3%)
SLIPPAGE_BPS=300

# SOL to keep in each ephemeral wallet for gas
GAS_RESERVE_SOL=0.01
